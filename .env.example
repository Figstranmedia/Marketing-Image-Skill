# Replicate API Configuration
# 1. Sign up: https://replicate.com (free with initial credits)
# 2. Copy your API token from https://replicate.com/account
# 3. Paste below:
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxx

# Anthropic API (para copywriting con Claude Haiku)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxx

# FLUX Model Selection
# - schnell: Fast, $0.003/image, 4 steps (prototypes & quick iterations)
# - pro: High quality, $0.04/image, 50 steps (production-grade)
FLUX_MODEL=schnell

# Optional: Logging
DEBUG=false
LOG_LEVEL=info

# Ruta al directorio de la skill (para portabilidad)
# Cambiar si la skill está en otra ubicación
SKILL_HOME=~/Desktop/marketing-image-skill

# Project defaults
DEFAULT_PROJECT_PATH=~/Desktop/raffaelmusic.com
DEFAULT_FORMAT=instagram-carousel
DEFAULT_SLIDES=3

# ComfyUI local (opcional — solo si usas --local)
# COMFYUI_API_URL=http://localhost:8188
# COMFYUI_MAX_WAIT=600000
# COMFYUI_FLUX_UNET=flux1-schnell-fp8.safetensors
# COMFYUI_CLIP1=clip_l.safetensors
# COMFYUI_CLIP2=t5xxl_fp8_e4m3fn.safetensors
# COMFYUI_VAE=ae.safetensors
